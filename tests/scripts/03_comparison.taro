// Comparison, equality, and logical operators.

print "=== equality ===";
print 1 == 1;         // true
print 1 == 2;         // false
print 1 != 2;         // true
print 1 != 1;         // false
print 1 == 1.0;       // cross-numeric equality
print nil == nil;     // true
print true == true;   // true
print true == false;  // false
print "a" == "a";     // true
print "a" != "b";     // true

print "=== comparison ===";
print 1 < 2;          // true
print 2 < 1;          // false
print 3 > 2;          // true
print 2 > 3;          // false
print 2 <= 2;         // true
print 3 <= 2;         // false
print 2 >= 2;         // true
print 1 >= 3;         // false

print "=== not ===";
print !true;          // false
print !false;         // true
print !!true;         // true (double negation)
print !nil;           // true (nil is falsey)

print "=== and ===";
print true and true;   // true
print true and false;  // false
print false and true;  // false
print false and false; // false
print 1 and 2;         // 2 (both truthy, returns second)

print "=== or ===";
print true or true;    // true
print true or false;   // true
print false or true;   // true
print false or false;  // false
print nil or 42;       // 42 (first truthy wins)

print "=== mixed logical ===";
print !true or false;         // false
print !(true or false);       // false
print true and !false;        // true
print (1 < 2) and (3 > 2);   // true
print (1 > 2) or (3 > 2);    // true

print "done";
