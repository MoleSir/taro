// Closure tests with upvalues

// === counting closure ===
fun makeCounter() {
    var i = 0;
    fun counter() {
        i = i + 1;
        return i;
    }
    return counter;
}

var c1 = makeCounter();
print(c1()); // 1
print(c1()); // 2
print(c1()); // 3

// === independent counters ===
var c2 = makeCounter();
print(c2()); // 1
print(c1()); // 4  (c1 and c2 are independent)

// === closure captures outer function parameter ===
fun makeAdder(x) {
    fun adder(y) {
        return x + y;
    }
    return adder;
}

var add5 = makeAdder(5);
print(add5(3)); // 8
print(add5(10)); // 15

// === nested closure captures from grandparent ===
fun outer() {
    var a = 10;
    fun middle() {
        fun inner() {
            return a; // captures 'a' from outer via chain
        }
        return inner;
    }
    return middle;
}

var getA = outer()();
print(getA()); // 10

print("done");
