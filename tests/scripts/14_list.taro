// List — comprehensive coverage

// === 1. Empty list ===
print("=== empty list ===");
var empty = [];
print(empty);           // []
print(len(empty));      // 0
print(bool(empty));     // false

// === 2. List literal ===
print("=== list literal ===");
var a = [1, 2, 3];
print(a);               // [1, 2, 3]
print(len(a));          // 3
print(bool(a));         // true

// === 3. Mixed types ===
print("=== mixed types ===");
var b = [1, "hello", true, nil, 3.14];
print(len(b));          // 5
print(b);

// === 4. Index get ===
print("=== index get ===");
print(a[0]);            // 1
print(a[1]);            // 2
print(a[2]);            // 3

// === 5. Negative index ===
print("=== negative index ===");
print(a[-1]);           // 3
print(a[-2]);           // 2
print(a[-3]);           // 1

// === 6. Index set ===
print("=== index set ===");
a[0] = 99;
a[1] = 88;
print(a);               // [99, 88, 3]

// === 7. Index set negative ===
print("=== index set negative ===");
a[-1] = 77;
print(a);               // [99, 88, 77]

// === 8. Nested lists ===
print("=== nested lists ===");
var m = [[1, 2], [3, 4], [5, 6]];
print(m[0]);            // [1, 2]
print(m[0][1]);         // 2
print(m[2][0]);         // 5

// === 9. Loop over list ===
print("=== loop over list ===");
var items = [10, 20, 30, 40];
var i = 0;
var sum = 0;
while (i < len(items)) {
    sum = sum + items[i];
    i = i + 1;
}
print(sum);             // 100

// === 10. Index set is expression ===
print("=== index set expression ===");
var x = [1, 2, 3];
var val = x[0] = 42;
print(val);             // 42
print(x[0]);            // 42

// === 11. List in variable assignment ===
print("=== list assignment ===");
var original = [1, 2, 3];
var copy = original;
copy[0] = 99;
print(original);        // [99, 2, 3] — same object

// === 12. List with functions ===
print("=== list functions ===");
fun make_list(a, b, c) {
    return [a, b, c];
}
print(make_list(1, 2, 3));

// === 13. __getitem__ magic ===
print("=== __getitem__ magic ===");
class Wrapper {
    fun __init__(self, v) {
        self.v = v;
    }
    fun __getitem__(self, idx) {
        return self.v;
    }
}
var w = Wrapper(42);
print(w[0]);            // 42
print(w[999]);          // 42

// === 14. __setitem__ magic ===
print("=== __setitem__ magic ===");
class Container {
    fun __init__(self) {
        self.inner = 0;
    }
    fun __getitem__(self, idx) {
        return self.inner;
    }
    fun __setitem__(self, idx, val) {
        self.inner = val;
    }
}
var c = Container();
print(c[0]);            // 0
c[0] = 99;
print(c[0]);            // 99

// === 15. List of instances ===
print("=== list of instances ===");
class Point {
    fun __init__(self, x, y) {
        self.x = x;
        self.y = y;
    }
    fun __str__(self) {
        return "(" + str(self.x) + "," + str(self.y) + ")";
    }
}
var points = [Point(1, 2), Point(3, 4), Point(5, 6)];
print(points);

// === 16. list() builtin ===
print("=== list() builtin ===");
var a = list(10, 20, 30);
print(a);                // [10, 20, 30]
print(len(a));           // 3
print(a[0]);             // 10

// === 17. list() empty ===
print("=== list() empty ===");
var empty = list();
print(empty);            // []
print(len(empty));       // 0
print(bool(empty));      // false

// === 18. list() with variables ===
print("=== list() with variables ===");
var x = 1;
var y = 2;
var z = list(x, y, x + y);
print(z);                // [1, 2, 3]

// === 19. list() vs [] ===
print("=== list() vs [] ===");
var lit = [1, 2, 3];
var fn = list(1, 2, 3);
print(lit);              // [1, 2, 3]
print(fn);               // [1, 2, 3]

print("list done");
