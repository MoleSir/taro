// Function declaration and calling.

print("=== simple function, no args ===");
fun greet() {
    print("hello from greet");
}
greet();

print("=== function with one param ===");
fun echo(msg) {
    print(msg);
}
echo("Taro says hi");

print("=== function with return value ===");
fun add(a, b) {
    return a + b;
}
print(add(3, 4));
print(add(10, 20));

print("=== function with implicit return (nil) ===");
fun noop() {}
var r = noop();
print(r);  // nil

print("=== function with early return ===");
fun early(x) {
    if (x > 5) {
        return 100;
    }
    return x;
}
print(early(3));
print(early(10));

print("=== function call as sub-expression ===");
fun double(n) {
    return n * 2;
}
print(double(5) + 1);    // 11
print(double(double(3))); // 12

print("=== nested function calls ===");
fun square(n) {
    return n * n;
}
fun sum_of_squares(a, b) {
    return square(a) + square(b);
}
print(sum_of_squares(3, 4));  // 9 + 16 = 25

print("=== function with multiple params ===");
fun sum3(a, b, c) {
    return a + b + c;
}
print(sum3(1, 2, 3));

print("=== function calling another global function ===");
fun f() {
    return 42;
}
fun g() {
    return f();
}
print(g());  // 42

print("=== function with 0 params that computes ===");
fun magic() {
    return 7 * 6;
}
print(magic());

print("done");
