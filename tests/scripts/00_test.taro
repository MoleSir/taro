class Toast {}
var toast = Toast();
print(toast.jam = "grape"); // Prints "grape".


class Pair {}

var pair = Pair();
pair.first = 1;
pair.second = 2;
print(pair.first + pair.second); // 3.


class Brioche {}
print(Brioche());

class Scone {
  fun topping(first, second) {
    print("scone with " + first + " and " + second);
  }
}

var scone = Scone();
scone.topping("berries", "cream");



class Nested {
  fun method() {
    fun function() {
      print(this);
    }

    print("in Nested::method");
    function();
  }
}

var n = Nested();
n.method();